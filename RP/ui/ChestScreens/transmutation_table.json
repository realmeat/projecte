  //elements
  "book": {
    "type": "image",
    "texture": "textures/gui/transmutation_book_overlay",
    "layer": 1,
    "alpha": 0.5,
    "size": [16, 16]
  },
  "flame": {
    "type": "image",
    "texture": "textures/ui/flame_full_image",
    "layer": 1,
    "size": [13, 13]
  },
  "slot": {
    "type": "stack_panel",
    "$index": 0,
    "$collection_name": "collection",
    "collection_name": "$collection_name",
    "$slot_size": [18, 18],
    "$slot_image_size": [18, 18],
    "controls": [
      {
        "slot@chest.chest_grid_item": {
          "ignored": false,
          "$cell_image_size": "$slot_image_size",
          "size": "$slot_size",
          "collection_index": "$index",
          "property_bag": {
            "#name": "[Empty]"
          },
          "bindings": [
            {
              "binding_name": "#hover_text",
              "binding_type": "collection",
              "binding_condition": "always",
              "binding_collection_name": "container_items"
            },
            {
              "binding_type": "view",
              "source_property_name": "(((#hover_text - #name) = #hover_text) and (not ((#name - ' ') = '')))",
              "target_property_name": "#active"
            },
            {
              "binding_type": "view",
              "source_property_name": "((#active))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },
  "text_display": {
    "type": "stack_panel",
    "$index": 0,
    "$collection_name": "collection",
    "size": [18, 18],
    "collection_name": "$collection_name",
    "controls": [
      {
        "text": {
          "type": "label",
          "text": "$hover_text_binding_name",
          "collection_index": "$index",
          "property_bag": {
            "#ttext": "teste"
          },
          "color": "$title_text_color",
          "$hover_text_binding_name": "#hover_text",
          "bindings": [
            {
              "binding_name_override": "#hover_text",
              "binding_name": "$hover_text_binding_name",
              "binding_condition": "always_when_visible",
              "binding_type": "collection",
              "binding_collection_name": "$collection_name"
            }
          ]
        }
      }
    ]
  },
  "slot_icon": {
    "type": "stack_panel",
    "$index": 0,
    "$collection_name": "collection",
    "collection_name": "$collection_name",
    "$slot_size": [18, 18],
    "$slot_image_size": [18, 18],
    "$sub_icon": "textues/items/diamond",
    "controls": [
      {
        "slot@common.icon_container_item": {
          "ignored": false,
          "$cell_image_size": "$slot_image_size",
          "size": "$slot_size",
          "$button_text": "$hover_text",
          "$icon_texture": "$sub_icon",
          "collection_index": "$index",
          "$item_collection_name": "$collection_name"
        }
      }
    ]
  },
