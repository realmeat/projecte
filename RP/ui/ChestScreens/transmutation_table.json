  "view": {
    "type": "button",
    "focus_enabled": true,
    "focus_wrap_enabled": false,
    "focus_magnet_enabled": true,
    "$highlight_control|default": "common.highlight_slot_panel",
    "default_focus_precedence": 1,
    "hover_control": "hover",
    "layer": 1,
    "controls": [
      {
        "hover@$highlight_control": {}
      },
      {
        "bundle_popup_factory_control": {
          "type": "panel",
          "factory": {
            "name": "bundle_popup_factory",
            "control_name": "common.bundle_mode_popup_control",
            "max_children_size": 1
          }
        }
      }
    ]
  },
